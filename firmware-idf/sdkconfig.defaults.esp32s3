# SPDX-License-Identifier: Apache-2.0
# ESP32-S3 overrides. Console on UART (flashed/monitored via the CH343 UART port),
# which is also the final design: the native USB is reserved for TinyUSB NCM in M5.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
# TinyUSB owns the native USB (USB-NCM), so the USB-Serial-JTAG console must be off.
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
# USB-NCM device class (esp_tinyusb).
CONFIG_TINYUSB_NET_MODE_NCM=y
# L2 bridge: Wi-Fi AP + USB-NCM share one subnet (172.20.1.1/26) so the EFB
# finds the AID at 172.20.1.1 whether it connects over Wi-Fi or the USB cable.
CONFIG_ESP_NETIF_BRIDGE_EN=y
CONFIG_LWIP_NUM_NETIF_CLIENT_DATA=2
CONFIG_LWIP_BRIDGEIF_MAX_PORTS=7
# Octal PSRAM (ESP32-S3R8, 8 MB) — enabled 2026-07-21 after live validation on
# Board 3: free heap went ~40 KB -> 8.3 MB and the Viasat poll path stopped
# starving internal SRAM. Guardrail CONFIG_SPIRAM_IGNORE_NOTFOUND=y makes a PSRAM
# init failure boot *without* PSRAM instead of looping; FETCH_INSTRUCTIONS/RODATA
# are deliberately left off so the 2nd-stage bootloader stays PSRAM-agnostic.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
# LVGL fonts for the T-Display-S3 flight display (14 is the LVGL default).
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_32=y
CONFIG_LV_FONT_MONTSERRAT_40=y
# LVGL's builtin pool comes from internal SRAM, which WiFi+TinyUSB+bridge already
# squeeze hard (~52 KB free at display init). The default 64 KB pool starved the
# DMA draw-buffer allocation (lvgl_port_add_disp -> NULL, the M-black-screen bug).
# Our UI is 6 labels; 16 KB is ample.
CONFIG_LV_MEM_SIZE_KILOBYTES=24
